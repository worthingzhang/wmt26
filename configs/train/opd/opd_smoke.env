# OPD smoke 训练配置
# 环境变量占位，供 train_opd.sh 读取并注入到 OPD/verl 训练脚本中。
# 不要写死具体实验模型路径。

# 模型路径（训练脚本注入）
OPD_STUDENT_MODEL_PATH=PLACEHOLDER
OPD_TEACHER_MODEL_PATH=PLACEHOLDER

# Prompt / 数据路径
OPD_PROMPT_PATH=PLACEHOLDER
OPD_COLDSTART_DATA_PATH=/home/zc/wmt26/data/processed/opd_coldstart

# 保存路径（训练脚本注入）
OPD_OUTPUT_DIR=PLACEHOLDER
OPD_LOG_DIR=PLACEHOLDER

# 生成参数
OPD_TOP_K=50
OPD_TOP_P=0.95
OPD_TEMPERATURE=0.7

# 长度参数
OPD_MAX_PROMPT_LENGTH=2048
OPD_MAX_RESPONSE_LENGTH=1024

# 训练参数（smoke）
OPD_NUM_EPOCHS=1
OPD_BATCH_SIZE=4
OPD_LEARNING_RATE=1.0e-6
OPD_WARMUP_STEPS=10

# verl / OPD 框架相关
OPD_BACKEND=verl
OPD_TRAINER=opd
OPD_NUM_GPUS=8
OPD_ZERO_STAGE=2

# 日志
OPD_LOGGING_STEPS=10
OPD_SAVE_STEPS=50

# 其他占位
OPD_SEED=42
OPD_BF16=true
